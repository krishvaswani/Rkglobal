{% comment %}
  Section: Onboarding Journey
  File: sections/onboarding-journey.liquid
  Compatible with: Shopify Horizon Theme
{% endcomment %}

<section
  class="onboarding-journey"
  style="background-color: {{ section.settings.background_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  id="onboarding-journey-{{ section.id }}"
>
  <div class="onboarding-journey__inner">

    {%- if section.settings.show_label or section.settings.title != blank -%}
      <div class="onboarding-journey__header">

        {%- if section.settings.show_label and section.settings.label != blank -%}
          <div class="onboarding-journey__label">
            <span class="onboarding-journey__dot"></span>
            {{ section.settings.label }}
          </div>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="onboarding-journey__title">{{ section.settings.title }}</h2>
        {%- endif -%}

        {%- if section.settings.subtitle != blank -%}
          <p class="onboarding-journey__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}

      </div>
    {%- endif -%}

    <div class="onboarding-journey__grid">
      {%- for block in section.blocks -%}
        <div
          class="onboarding-journey__card"
          {{ block.shopify_attributes }}
          style="
            {%- if block.settings.background_image != blank -%}
              --card-bg-image: url('{{ block.settings.background_image | image_url: width: 600 }}');
            {%- else -%}
              --card-bg-image: none;
            {%- endif -%}
            --card-bg-color: {{ block.settings.card_bg_color }};
          "
        >
          <div class="onboarding-journey__bg"></div>
          <div class="onboarding-journey__overlay" style="background: {{ block.settings.overlay_color }};"></div>
          <div class="onboarding-journey__content">

            {%- if section.settings.show_step_numbers -%}
              <span class="onboarding-journey__number">{{ forloop.index }}</span>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="onboarding-journey__card-title" style="color: {{ section.settings.card_title_color }};">
                {{ block.settings.title }}
              </h3>
            {%- endif -%}

            {%- if block.settings.description != blank -%}
              <p class="onboarding-journey__card-text">{{ block.settings.description }}</p>
            {%- endif -%}

            {%- if block.settings.link_label != blank and block.settings.link_url != blank -%}
              <a class="onboarding-journey__card-link" href="{{ block.settings.link_url }}">
                {{ block.settings.link_label }}
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- endif -%}

          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
      <div class="onboarding-journey__footer">
        <a class="onboarding-journey__cta" href="{{ section.settings.cta_url }}">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
/* ============================================
   ONBOARDING JOURNEY — Shopify Liquid Section
   ============================================ */

#onboarding-journey-{{ section.id }} {
  font-family: inherit;
  box-sizing: border-box;
  padding-left: 24px;
  padding-right: 24px;
}

#onboarding-journey-{{ section.id }} *,
#onboarding-journey-{{ section.id }} *::before,
#onboarding-journey-{{ section.id }} *::after {
  box-sizing: border-box;
}

#onboarding-journey-{{ section.id }} .onboarding-journey__inner {
  max-width: 1280px;
  margin: 0 auto;
}

/* --- Header --- */
#onboarding-journey-{{ section.id }} .onboarding-journey__header {
  margin-bottom: 40px;
}

#onboarding-journey-{{ section.id }} .onboarding-journey__label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background-color: #fff3e0;
  border: 1px solid #f5c98a;
  border-radius: 999px;
  padding: 6px 14px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: #5c3d1e;
  text-transform: uppercase;
  margin-bottom: 16px;
}

#onboarding-journey-{{ section.id }} .onboarding-journey__dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background-color: {{ section.settings.accent_color }};
  flex-shrink: 0;
}

#onboarding-journey-{{ section.id }} .onboarding-journey__title {
  font-size: clamp(26px, 4vw, 42px);
  font-weight: 800;
  color: {{ section.settings.heading_color }};
  line-height: 1.2;
  margin: 0 0 12px 0;
  max-width: 720px;
}

#onboarding-journey-{{ section.id }} .onboarding-journey__subtitle {
  font-size: 16px;
  color: {{ section.settings.heading_color }};
  opacity: 0.65;
  margin: 0;
  max-width: 580px;
  line-height: 1.6;
}

/* --- Grid --- */
#onboarding-journey-{{ section.id }} .onboarding-journey__grid {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  gap: {{ section.settings.card_gap }}px;
}

/* --- Card --- */
#onboarding-journey-{{ section.id }} .onboarding-journey__card {
  position: relative;
  border-radius: {{ section.settings.card_border_radius }}px;
  overflow: hidden;
  min-height: {{ section.settings.card_min_height }}px;
  display: flex;
  flex-direction: column;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

#onboarding-journey-{{ section.id }} .onboarding-journey__card:hover {
  transform: translateY(-5px);
  box-shadow: 0 20px 48px rgba(0, 0, 0, 0.3);
}

/* --- Card background image --- */
#onboarding-journey-{{ section.id }} .onboarding-journey__bg {
  position: absolute;
  inset: 0;
  background-color: var(--card-bg-color);
  background-image: var(--card-bg-image);
  background-size: cover;
  background-position: center;
  z-index: 0;
  transition: transform 0.4s ease;
}

#onboarding-journey-{{ section.id }} .onboarding-journey__card:hover .onboarding-journey__bg {
  transform: scale(1.04);
}

/* --- Overlay --- */
#onboarding-journey-{{ section.id }} .onboarding-journey__overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
}

/* --- Content --- */
#onboarding-journey-{{ section.id }} .onboarding-journey__content {
  position: relative;
  z-index: 2;
  padding: 22px 20px 24px;
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* --- Number badge --- */
#onboarding-journey-{{ section.id }} .onboarding-journey__number {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  background-color: #f5ead8;
  color: #3d2008;
  font-size: 14px;
  font-weight: 800;
  border-radius: 10px;
  margin-bottom: 18px;
  flex-shrink: 0;
  align-self: flex-start;
}

/* --- Card title --- */
#onboarding-journey-{{ section.id }} .onboarding-journey__card-title {
  font-size: 17px;
  font-weight: 800;
  margin: 0 0 10px 0;
  line-height: 1.25;
}

/* --- Card text --- */
#onboarding-journey-{{ section.id }} .onboarding-journey__card-text {
  font-size: 13.5px;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.65;
  margin: 0 0 14px 0;
  flex: 1;
}

/* --- Card link --- */
#onboarding-journey-{{ section.id }} .onboarding-journey__card-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 700;
  color: {{ section.settings.accent_color }};
  text-decoration: none;
  margin-top: auto;
  transition: gap 0.2s ease;
}

#onboarding-journey-{{ section.id }} .onboarding-journey__card-link:hover {
  gap: 10px;
}

/* --- CTA Footer --- */
#onboarding-journey-{{ section.id }} .onboarding-journey__footer {
  margin-top: 40px;
  text-align: {{ section.settings.cta_alignment }};
}

#onboarding-journey-{{ section.id }} .onboarding-journey__cta {
  display: inline-block;
  background-color: {{ section.settings.accent_color }};
  color: #ffffff;
  font-size: 15px;
  font-weight: 700;
  padding: 14px 32px;
  border-radius: 999px;
  text-decoration: none;
  transition: opacity 0.2s ease, transform 0.2s ease;
  letter-spacing: 0.02em;
}

#onboarding-journey-{{ section.id }} .onboarding-journey__cta:hover {
  opacity: 0.88;
  transform: translateY(-2px);
}

/* ============================================
   RESPONSIVE
   ============================================ */
@media (max-width: 1024px) {
  #onboarding-journey-{{ section.id }} .onboarding-journey__grid {
    grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
  }
}

@media (max-width: 768px) {
  #onboarding-journey-{{ section.id }} {
    padding-left: 16px;
    padding-right: 16px;
  }

  #onboarding-journey-{{ section.id }} .onboarding-journey__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  #onboarding-journey-{{ section.id }} .onboarding-journey__card {
    min-height: 210px;
  }

  #onboarding-journey-{{ section.id }} .onboarding-journey__card-title {
    font-size: 15px;
  }

  #onboarding-journey-{{ section.id }} .onboarding-journey__card-text {
    font-size: 13px;
  }
}

@media (max-width: 480px) {
  #onboarding-journey-{{ section.id }} .onboarding-journey__grid {
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    gap: 12px;
  }

  #onboarding-journey-{{ section.id }} .onboarding-journey__card {
    min-height: 190px;
  }

  #onboarding-journey-{{ section.id }} .onboarding-journey__title {
    font-size: 24px;
  }
}
</style>

{% schema %}
{
  "name": "Onboarding Journey",
  "tag": "section",
  "class": "onboarding-journey-section",
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "checkbox",
      "id": "show_label",
      "label": "Show label badge",
      "default": true
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label text",
      "default": "ONBOARDING JOURNEY"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "What happens after a salon partner enquiry is submitted"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subheading (optional)",
      "default": ""
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#f5f0e8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1008"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (badge dot, card titles, CTA)",
      "default": "#e07b2a"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title color",
      "default": "#e07b2a"
    },
    {
      "type": "header",
      "content": "Card Settings"
    },
    {
      "type": "checkbox",
      "id": "show_step_numbers",
      "label": "Show step numbers",
      "default": true
    },
    {
      "type": "range",
      "id": "card_min_height",
      "label": "Card minimum height (px)",
      "min": 160,
      "max": 420,
      "step": 10,
      "default": 260
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius (px)",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 18
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards (px)",
      "min": 4,
      "max": 32,
      "step": 2,
      "default": 14
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ],
      "default": "6"
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Columns on tablet",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": ""
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button URL"
    },
    {
      "type": "select",
      "id": "cta_alignment",
      "label": "CTA alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Lead submission"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step description",
          "default": "Owner submits salon type, city, billing potential and preferred partnership tier."
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Card background image"
        },
        {
          "type": "color",
          "id": "card_bg_color",
          "label": "Card background color (fallback)",
          "default": "#1e1209"
        },
        {
          "type": "color_background",
          "id": "overlay_color",
          "label": "Card overlay gradient",
          "default": "linear-gradient(160deg, rgba(20,10,3,0.55) 0%, rgba(10,5,0,0.82) 100%)"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label (optional)",
          "default": ""
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Onboarding Journey",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Lead submission",
            "description": "Owner submits salon type, city, billing potential and preferred partnership tier.",
            "card_bg_color": "#1e1209"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Initial review",
            "description": "Team checks fit based on city, scale, salon positioning and business seriousness.",
            "card_bg_color": "#1a1208"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Business call",
            "description": "Discussion on current setup, service mix, growth expectations and support needed.",
            "card_bg_color": "#150f08"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Tier recommendation",
            "description": "Salon is mapped to Silver, Gold, Platinum or franchise pathway based on readiness.",
            "card_bg_color": "#1c1108"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Activation plan",
            "description": "Training, branding, content and promotion inputs are aligned to the chosen tier.",
            "card_bg_color": "#181008"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Partner onboarding",
            "description": "Commercial onboarding and support rollout begin according to approved structure.",
            "card_bg_color": "#1e1308"
          }
        }
      ]
    }
  ]
}
{% endschema %}
