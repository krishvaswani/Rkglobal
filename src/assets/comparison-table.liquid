{% comment %}
  Comparison Table Section - Fast comparison for decision-makers
  Compatible with Shopify Horizon theme
{% endcomment %}

<section class="comparison-table-section" id="comparison-table-{{ section.id }}">
  <div class="comparison-table-section__outer">
    <div class="comparison-table-section__inner">

      <div class="ct-header">
        {% if section.settings.show_badge and section.settings.badge_text != blank %}
          <div class="ct-badge">
            <span class="ct-badge__dot"></span>
            {{ section.settings.badge_text }}
          </div>
        {% endif %}
        <h2 class="ct-title">{{ section.settings.title }}</h2>
        {% if section.settings.subtitle != blank %}
          <p class="ct-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>

      <div class="ct-table-wrap">
        <table class="ct-table">
          <thead>
            <tr>
              <th class="ct-th ct-th--privilege">{{ section.settings.col_privilege }}</th>
              <th class="ct-th">{{ section.settings.col_silver }}</th>
              <th class="ct-th">{{ section.settings.col_gold }}</th>
              <th class="ct-th">{{ section.settings.col_platinum }}</th>
            </tr>
          </thead>
          <tbody>
            {% for block in section.blocks %}
              <tr class="ct-row" {{ block.shopify_attributes }}>
                <td class="ct-td ct-td--label">{{ block.settings.privilege }}</td>
                <td class="ct-td">{{ block.settings.silver }}</td>
                <td class="ct-td">{{ block.settings.gold }}</td>
                <td class="ct-td">{{ block.settings.platinum }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

    </div>
  </div>
</section>

<style>
  #comparison-table-{{ section.id }} {
    --ct-page-bg: {{ section.settings.color_page_bg }};
    --ct-card-bg: {{ section.settings.color_card_bg }};
    --ct-accent: {{ section.settings.color_accent }};
    --ct-heading: {{ section.settings.color_heading }};
    --ct-col-header: {{ section.settings.color_col_header }};
    --ct-label: {{ section.settings.color_label }};
    --ct-cell: {{ section.settings.color_cell }};
    --ct-border: {{ section.settings.color_border }};
    --ct-badge-bg: #fff7f0;
    --ct-badge-border: #f0d8c4;
    --ct-radius: {{ section.settings.card_radius }}px;
    font-family: inherit;
  }

  #comparison-table-{{ section.id }} .comparison-table-section {
    background: var(--ct-page-bg);
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
  }

  #comparison-table-{{ section.id }} .comparison-table-section__outer {
    max-width: 1280px;
    margin: 0 auto;
  }

  #comparison-table-{{ section.id }} .comparison-table-section__inner {
    background: var(--ct-card-bg);
    border-radius: var(--ct-radius);
    padding: 48px 52px 52px;
    box-shadow: 0 2px 20px rgba(0,0,0,0.05);
  }

  /* Badge */
  #comparison-table-{{ section.id }} .ct-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: var(--ct-badge-bg);
    border: 1px solid var(--ct-badge-border);
    color: var(--ct-accent);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 13px;
    border-radius: 20px;
    margin-bottom: 14px;
  }

  #comparison-table-{{ section.id }} .ct-badge__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--ct-accent);
    flex-shrink: 0;
    display: inline-block;
  }

  /* Header */
  #comparison-table-{{ section.id }} .ct-header {
    margin-bottom: 36px;
  }

  #comparison-table-{{ section.id }} .ct-title {
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 800;
    color: var(--ct-heading);
    line-height: 1.12;
    margin: 0 0 10px;
    letter-spacing: -0.025em;
  }

  #comparison-table-{{ section.id }} .ct-subtitle {
    font-size: 15px;
    color: var(--ct-label);
    margin: 0;
    line-height: 1.6;
  }

  /* Table wrap for horizontal scroll on mobile */
  #comparison-table-{{ section.id }} .ct-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  /* Table */
  #comparison-table-{{ section.id }} .ct-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 600px;
  }

  /* Column headers */
  #comparison-table-{{ section.id }} .ct-th {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ct-col-header);
    padding: 0 16px 16px 0;
    text-align: left;
    border-bottom: 1.5px solid var(--ct-border);
    white-space: nowrap;
  }

  #comparison-table-{{ section.id }} .ct-th--privilege {
    width: 22%;
    min-width: 160px;
  }

  /* Rows */
  #comparison-table-{{ section.id }} .ct-row {
    border-bottom: 1px solid var(--ct-border);
    transition: background 0.15s;
  }

  #comparison-table-{{ section.id }} .ct-row:last-child {
    border-bottom: none;
  }

  #comparison-table-{{ section.id }} .ct-row:hover {
    background: #faf7f4;
  }

  /* Cells */
  #comparison-table-{{ section.id }} .ct-td {
    font-size: 14px;
    color: var(--ct-cell);
    padding: 18px 16px 18px 0;
    vertical-align: top;
    line-height: 1.5;
  }

  #comparison-table-{{ section.id }} .ct-td--label {
    font-size: 14px;
    color: var(--ct-label);
    font-weight: 400;
    min-width: 160px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    #comparison-table-{{ section.id }} .comparison-table-section__inner {
      padding: 32px 24px 36px;
    }
  }
</style>

{% schema %}
{
