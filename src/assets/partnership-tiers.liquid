{% comment %}
  Partnership Tiers Section - Silver, Gold, Platinum
  Compatible with Shopify Horizon theme
{% endcomment %}

<section class="partnership-tiers" id="partnership-tiers-{{ section.id }}">
  <div class="partnership-tiers__container">

    <div class="partnership-tiers__header">
      {% if section.settings.show_badge and section.settings.badge_text != blank %}
        <div class="partnership-tiers__badge">
          <span class="badge-dot"></span>
          {{ section.settings.badge_text }}
        </div>
      {% endif %}
      <h2 class="partnership-tiers__title">{{ section.settings.title }}</h2>
      {% if section.settings.subtitle != blank %}
        <div class="partnership-tiers__subtitle">{{ section.settings.subtitle }}</div>
      {% endif %}
    </div>

    <div class="partnership-tiers__grid">
      {% for block in section.blocks %}
        {% assign is_featured = block.settings.featured %}
        {% assign card_bg = block.settings.card_bg_override | default: section.settings.color_card_bg %}
        {% assign label_color = block.settings.label_color_override | default: section.settings.color_accent %}
        {% assign price_color = block.settings.price_color_override | default: section.settings.color_accent %}
        <div class="tier-card {% if is_featured %}tier-card--featured{% endif %}"
             style="--pt-card-bg-local: {{ card_bg }}; --pt-label-color-local: {{ label_color }}; --pt-price-color-local: {{ price_color }};"
             {{ block.shopify_attributes }}>
          {% if block.settings.label != blank %}
            <div class="tier-card__label">{{ block.settings.label }}</div>
          {% endif %}

          <h3 class="tier-card__name">{{ block.settings.name }}</h3>

          <div class="tier-card__price">{{ block.settings.price }}</div>
          <p class="tier-card__billing">{{ block.settings.billing_text }}</p>

          <ul class="tier-card__features">
            {% assign features = block.settings.features | newline_to_br | split: '<br />' %}
            {% for feature in features %}
              {% assign feature = feature | strip %}
              {% if feature != blank %}
                <li class="tier-card__feature-item">
                  <span class="tier-card__feature-dot"></span>
                  <span>{{ feature }}</span>
                </li>
              {% endif %}
            {% endfor %}
          </ul>

          <div class="tier-card__cta">
            {% if block.settings.button_link != blank %}
              <a href="{{ block.settings.button_link }}" target="{{ block.settings.button_target }}" class="tier-card__button {% if is_featured %}tier-card__button--featured{% endif %}">
                {{ block.settings.button_text }}
              </a>
            {% else %}
              <button class="tier-card__button {% if is_featured %}tier-card__button--featured{% endif %}">
                {{ block.settings.button_text }}
              </button>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
  #partnership-tiers-{{ section.id }} {
    --pt-bg: {{ section.settings.color_bg }};
    --pt-card-bg: {{ section.settings.color_card_bg }};
    --pt-accent: {{ section.settings.color_accent }};
    --pt-accent-light: {{ section.settings.color_accent_light }};
    --pt-text-dark: {{ section.settings.color_text_dark }};
    --pt-text-mid: {{ section.settings.color_text_mid }};
    --pt-text-muted: {{ section.settings.color_text_muted }};
    --pt-border: {{ section.settings.color_card_border }};
    --pt-dot: {{ section.settings.color_accent }};
    --pt-heading-color: {{ section.settings.color_heading }};
    --pt-radius-card: {{ section.settings.card_border_radius }}px;
    --pt-radius-label: 8px;
    --pt-radius-btn: 10px;
    --pt-card-padding: {{ section.settings.card_padding }}px;
    --pt-card-gap: {{ section.settings.card_gap }}px;
    font-family: inherit;
  }

  #partnership-tiers-{{ section.id }} .partnership-tiers {
    background: var(--pt-bg);
    padding: {{ section.settings.section_padding_top }}px 20px {{ section.settings.section_padding_bottom }}px;
  }

  #partnership-tiers-{{ section.id }} .partnership-tiers__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Header */
  #partnership-tiers-{{ section.id }} .partnership-tiers__header {
    margin-bottom: 40px;
    text-align: {{ section.settings.heading_align }};
  }

  #partnership-tiers-{{ section.id }} .partnership-tiers__badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: #fff7f0;
    border: 1px solid #f0d8c4;
    color: var(--pt-accent);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 20px;
    margin-bottom: 14px;
  }

  #partnership-tiers-{{ section.id }} .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--pt-accent);
    display: inline-block;
    flex-shrink: 0;
  }

  {% case section.settings.heading_size %}
    {% when 'small' %}{% assign heading_px = '28px' %}
    {% when 'medium' %}{% assign heading_px = '36px' %}
    {% when 'large' %}{% assign heading_px = '42px' %}
    {% when 'xlarge' %}{% assign heading_px = '52px' %}
    {% else %}{% assign heading_px = '42px' %}
  {% endcase %}

  #partnership-tiers-{{ section.id }} .partnership-tiers__title {
    font-size: clamp(24px, 4vw, {{ heading_px }});
    font-weight: 800;
    color: var(--pt-heading-color);
    line-height: 1.15;
    margin: 0;
    letter-spacing: -0.02em;
  }

  #partnership-tiers-{{ section.id }} .partnership-tiers__subtitle {
    font-size: 16px;
    color: var(--pt-text-mid);
    margin: 12px 0 0;
    line-height: 1.6;
  }

  /* Grid */
  #partnership-tiers-{{ section.id }} .partnership-tiers__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: var(--pt-card-gap);
    align-items: start;
  }

  @media (max-width: {{ section.settings.mobile_breakpoint }}px) {
    #partnership-tiers-{{ section.id }} .partnership-tiers__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
    }
  }

  /* Card */
  #partnership-tiers-{{ section.id }} .tier-card {
    background: var(--pt-card-bg-local, var(--pt-card-bg));
    border-radius: var(--pt-radius-card);
    padding: var(--pt-card-padding);
    padding-bottom: calc(var(--pt-card-padding) + 4px);
    display: flex;
    flex-direction: column;
    border: {% if section.settings.card_border_style == 'solid' %}1px solid var(--pt-border){% else %}none{% endif %};
    box-shadow: {% if section.settings.card_shadow %}0 2px 12px rgba(0,0,0,0.04){% else %}none{% endif %};
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  #partnership-tiers-{{ section.id }} .tier-card:hover {
    {% if section.settings.card_hover_lift %}
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    transform: translateY(-2px);
    {% endif %}
  }

  /* Label */
  #partnership-tiers-{{ section.id }} .tier-card__label {
    background: var(--pt-accent-light);
    color: var(--pt-label-color-local, var(--pt-accent));
    font-size: 12px;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: var(--pt-radius-label);
    display: inline-block;
    margin-bottom: 16px;
    letter-spacing: 0.02em;
  }

  /* Name */
  #partnership-tiers-{{ section.id }} .tier-card__name {
    font-size: 20px;
    font-weight: 700;
    color: var(--pt-text-dark);
    margin: 0 0 16px;
    letter-spacing: -0.01em;
  }

  /* Price */
  #partnership-tiers-{{ section.id }} .tier-card__price {
    font-size: 36px;
    font-weight: 800;
    color: var(--pt-price-color-local, var(--pt-accent));
    margin-bottom: 4px;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  #partnership-tiers-{{ section.id }} .tier-card__billing {
    font-size: 13px;
    color: var(--pt-text-muted);
    margin: 0 0 24px;
  }

  /* Features */
  #partnership-tiers-{{ section.id }} .tier-card__features {
    list-style: none;
    margin: 0 0 32px;
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #partnership-tiers-{{ section.id }} .tier-card__feature-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--pt-text-mid);
    line-height: 1.45;
  }

  #partnership-tiers-{{ section.id }} .tier-card__feature-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--pt-dot);
    flex-shrink: 0;
    margin-top: 5px;
  }

  /* CTA */
  #partnership-tiers-{{ section.id }} .tier-card__cta {
    margin-top: auto;
  }

  #partnership-tiers-{{ section.id }} .tier-card__button {
    display: block;
    width: 100%;
    text-align: center;
    padding: 13px 20px;
    border-radius: var(--pt-radius-btn);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    border: 1.5px solid var(--pt-text-dark);
    background: transparent;
    color: var(--pt-text-dark);
    transition: background 0.18s, color 0.18s, border-color 0.18s;
    letter-spacing: 0.01em;
    box-sizing: border-box;
  }

  #partnership-tiers-{{ section.id }} .tier-card__button:hover {
    background: var(--pt-text-dark);
    color: #fff;
  }

  #partnership-tiers-{{ section.id }} .tier-card__button--featured {
    background: var(--pt-accent);
    color: #fff;
    border-color: var(--pt-accent);
  }

  #partnership-tiers-{{ section.id }} .tier-card__button--featured:hover {
    background: #a34a10;
    border-color: #a34a10;
    color: #fff;
  }
</style>

{% schema %}
{
  "name": "Partnership Tiers",
  "tag": "section",
  "class": "section-partnership-tiers",
  "settings": [
    {
      "type": "header",
